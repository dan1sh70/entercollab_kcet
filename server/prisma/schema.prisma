generator client {
  provider = "prisma-client-js"
  // Build into prisma_tmp first (nothing loads that path). prisma-generate.mjs then moves it
  // to prisma/ so EPERM from a running dev server cannot block the engine file rename step.
  output   = "../src/generated/prisma_tmp"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                Int       @id @default(autoincrement())
  name              String
  email             String    @unique
  emailVerifiedAt   DateTime? @map("email_verified_at")
  password          String
  bio               String?
  university        String?
  major             String?
  profilePhotoPath  String?   @map("profile_photo_path")
  isAdmin           Int       @default(0) @map("is_admin")
  rememberToken     String?   @map("remember_token")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Extra profile fields
  connections  String?
  following    String?
  trustPoints  String? @map("trust_points")
  projects     String?
  collabs      String?
  skills       String?
  reach        String?

  // Institution fields
  accountType      String   @default("student") @map("account_type")
  institutionKind  String?  @map("institution_kind")
  managedCollegeId Int?     @map("managed_college_id")

  // Extended profile
  nationality     String?
  location        String?
  phone           String?
  website         String?
  githubHandle    String? @map("github_handle")
  linkedinHandle  String? @map("linkedin_handle")
  twitterHandle   String? @map("twitter_handle")

  // Relations
  posts              Post[]
  likes              Like[]
  comments           Comment[]
  projectRequests    ProjectRequest[]
  messages           Message[]
  chatRooms          ChatRoomUser[]
  trustPointRecords  TrustPoint[]       @relation("userTrustPoints")
  endorsementsGiven  Endorsement[]      @relation("endorser")
  endorsementsRecvd  Endorsement[]      @relation("endorsed")
  badges             BadgeUser[]
  colleges           CollegeUser[]
  activities         ActivityFeedItem[]
  bookmarks          Bookmark[]
  researchPapers     ResearchPaper[]
  events             Event[]
  eventRegs          EventRegistration[]
  aiRequests         AIRequest[]
  boardTasks         BoardTask[]        @relation("taskCreator")
  assignedTasks      BoardTask[]        @relation("taskAssignee")
  notifications      Notification[]

  followersRel  UserFollow[] @relation("followTarget")
  followingRel  UserFollow[] @relation("followSource")

  managedCollege College? @relation("managedCollege", fields: [managedCollegeId], references: [id])

  @@map("users")
}

model Post {
  id              Int       @id @default(autoincrement())
  publicId        String?   @unique @default(cuid()) @map("public_id")
  userId          Int       @map("user_id")
  title           String?
  category        String?
  content         String?
  image           String?
  media           String?
  type            String    @default("text")
  status          String    @default("published")
  scheduledAt     DateTime? @map("scheduled_at")
  visibility      String    @default("public")
  isPinned        Int       @default(0) @map("is_pinned")
  isFeatured      Int       @default(0) @map("is_featured")
  slug            String?
  metaTitle       String?   @map("meta_title")
  metaDescription String?   @map("meta_description")
  tags            String?
  location        String?
  likesCount      Int       @default(0) @map("likes_count")
  commentsCount   Int       @default(0) @map("comments_count")
  sharesCount     Int       @default(0) @map("shares_count")
  collegeId       Int?      @map("college_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes      Like[]
  comments   Comment[]
  requests   ProjectRequest[]
  boards     ProjectBoard[]
  bookmarks  Bookmark[]
  chatRooms  ChatRoom[]

  @@map("posts")
}

model Like {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  postId    Int      @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("likes")
}

model Comment {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  postId     Int       @map("post_id")
  parentId   Int?      @map("parent_id")
  content    String
  media      String?
  likesCount Int       @default(0) @map("likes_count")
  isEdited   Int       @default(0) @map("is_edited")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent Comment? @relation("commentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("commentReplies")

  @@map("comments")
}

model ProjectRequest {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  postId    Int      @map("post_id")
  approved  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("project_requests")
}

model ChatRoom {
  id        Int      @id @default(autoincrement())
  name      String
  postId    Int?     @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post       Post?          @relation(fields: [postId], references: [id], onDelete: Cascade)
  users      ChatRoomUser[]
  messages   Message[]
  aiRequests AIRequest[]

  @@map("chat_rooms")
}

model ChatRoomUser {
  id         Int      @id @default(autoincrement())
  chatRoomId Int      @map("chat_room_id")
  userId     Int      @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatRoomId, userId])
  @@map("chat_room_user")
}

model Message {
  id         Int      @id @default(autoincrement())
  chatRoomId Int      @map("chat_room_id")
  userId     Int      @map("user_id")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model AIRequest {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  chatRoomId   Int?     @map("chat_room_id")
  type         String
  prompt       String
  contextData  String?  @map("context_data")
  status       String   @default("pending")
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user     User        @relation(fields: [userId], references: [id])
  chatRoom ChatRoom?   @relation(fields: [chatRoomId], references: [id])
  response AIResponse?

  @@map("ai_requests")
}

model AIResponse {
  id              Int      @id @default(autoincrement())
  aiRequestId     Int      @unique @map("ai_request_id")
  content         String
  tokensUsed      Int?     @map("tokens_used")
  processingTimeMs Int?    @map("processing_time_ms")
  modelUsed       String?  @map("model_used")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  request AIRequest @relation(fields: [aiRequestId], references: [id])

  @@map("ai_responses")
}

model TrustPoint {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  action        String
  points        Int
  referenceType String?  @map("reference_type")
  referenceId   Int?     @map("reference_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation("userTrustPoints", fields: [userId], references: [id])

  @@map("trust_points")
}

model Endorsement {
  id         Int      @id @default(autoincrement())
  endorserId Int      @map("endorser_id")
  endorsedId Int      @map("endorsed_id")
  skill      String
  comment    String?
  projectId  Int?     @map("project_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  endorser User @relation("endorser", fields: [endorserId], references: [id])
  endorsed User @relation("endorsed", fields: [endorsedId], references: [id])

  @@map("endorsements")
}

model Badge {
  id             Int      @id @default(autoincrement())
  name           String
  slug           String   @unique
  description    String?
  icon           String?
  pointsRequired Int      @default(0) @map("points_required")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  users BadgeUser[]

  @@map("badges")
}

model BadgeUser {
  id        Int      @id @default(autoincrement())
  badgeId   Int      @map("badge_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  badge Badge @relation(fields: [badgeId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([badgeId, userId])
  @@map("badge_user")
}

model College {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  domain      String?
  logo        String?
  description String?
  website     String?
  isVerified  Int      @default(0) @map("is_verified")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users    CollegeUser[]
  managers User[]        @relation("managedCollege")

  @@map("colleges")
}

model CollegeUser {
  id         Int       @id @default(autoincrement())
  collegeId  Int       @map("college_id")
  userId     Int       @map("user_id")
  role       String?   @default("student")
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  college College @relation(fields: [collegeId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([collegeId, userId])
  @@map("college_user")
}

model ProjectBoard {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Post          @relation(fields: [projectId], references: [id])
  columns BoardColumn[]

  @@map("project_boards")
}

model BoardColumn {
  id         Int      @id @default(autoincrement())
  boardId    Int      @map("board_id")
  name       String
  orderIndex Int      @default(0) @map("order_index")
  color      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  board ProjectBoard @relation(fields: [boardId], references: [id])
  tasks BoardTask[]

  @@map("board_columns")
}

model BoardTask {
  id         Int       @id @default(autoincrement())
  columnId   Int       @map("column_id")
  userId     Int?      @map("user_id")
  assignedTo Int?      @map("assigned_to")
  title      String
  description String?
  orderIndex Int       @default(0) @map("order_index")
  dueDate    DateTime? @map("due_date")
  priority   String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  column   BoardColumn @relation(fields: [columnId], references: [id])
  creator  User?       @relation("taskCreator", fields: [userId], references: [id])
  assignee User?       @relation("taskAssignee", fields: [assignedTo], references: [id])

  @@map("board_tasks")
}

model UserFollow {
  id          Int      @id @default(autoincrement())
  followerId  Int      @map("follower_id")
  followingId Int      @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  follower  User @relation("followSource", fields: [followerId], references: [id])
  following User @relation("followTarget", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@map("user_follows")
}

model ActivityFeedItem {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  type        String
  subjectType String?  @map("subject_type")
  subjectId   Int?     @map("subject_id")
  metadata    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("activity_feed_items")
}

model Event {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  title        String
  description  String
  location     String
  image        String?
  eventDate    DateTime  @map("event_date")
  maxAttendees Int?      @map("max_attendees")
  status       String    @default("upcoming")
  type         String
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user          User                @relation(fields: [userId], references: [id])
  registrations EventRegistration[]

  @@map("events")
}

model EventRegistration {
  id        Int      @id @default(autoincrement())
  eventId   Int      @map("event_id")
  userId    Int      @map("user_id")
  status    String   @default("registered")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@map("event_registrations")
}

model ResearchPaper {
  id              Int       @id @default(autoincrement())
  publicId        String?   @unique @default(cuid()) @map("public_id")
  userId          Int       @map("user_id")
  title           String
  abstract        String?
  authors         String?
  field           String?
  filePath        String?   @map("file_path")
  doi             String?
  publicationDate DateTime? @map("publication_date")
  citations       Int?      @default(0)
  status          String    @default("draft")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("research_papers")
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  postId    Int      @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
  @@map("bookmarks")
}


model Notification {
  id             String    @id @default(cuid())
  type           String
  notifiableType String    @map("notifiable_type")
  notifiableId   Int       @map("notifiable_id")
  data           String
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [notifiableId], references: [id])

  @@map("notifications")
}
