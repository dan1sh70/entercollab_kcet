{
  "name": "server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "kill-port 3001 && tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/prisma-generate.mjs && tsc || echo tsc-warnings-ignored",
    "start": "node dist/index.js",
    "db:pull": "prisma db pull",
    "db:clean-prisma": "node scripts/clean-prisma.mjs",
    "db:generate": "node scripts/prisma-generate.mjs",
    "db:regenerate": "node scripts/clean-prisma.mjs && node scripts/prisma-generate.mjs",
    "db:push": "prisma db push",
    "db:seed": "tsx src/seed.ts",
    "db:backfill-chat-members": "tsx src/scripts/backfill_project_chat_members.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.4",
    "openai": "^6.37.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.0",
    "@types/nodemailer": "^7.0.11",
    "kill-port": "^2.0.1",
    "prisma": "^6.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
