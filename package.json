{
  "name": "intercollab",
  "private": true,
  "workspaces": ["server", "client"],
  "scripts": {
    "dev": "concurrently -c \"#93c5fd,#c4b5fd\" \"npm run dev --workspace=server\" \"npm run dev --workspace=client\" --names=server,client --kill-others",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "start": "npm run start --workspace=server",
    "db:generate": "npm run db:generate --workspace=server",
    "db:clean-prisma": "npm run db:clean-prisma --workspace=server",
    "db:regenerate": "npm run db:regenerate --workspace=server",
    "db:push": "npm run db:push --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
